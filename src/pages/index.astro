              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Badewanne</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> WLAN</span>
            </div>
            <AvailabilityCalendar apartment="bergwiese" id="bergwiese" />
            <div class="mt-4 border-t border-gray-200 dark:border-slate-700 pt-4">
              <div class="flex flex-wrap gap-3 mb-3">
                <div>
                  <label for="bfw-pc-checkin-bergwiese" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Anreise</label>
                  <input type="date" id="bfw-pc-checkin-bergwiese" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
                <div>
                  <label for="bfw-pc-checkout-bergwiese" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Abreise</label>
                  <input type="date" id="bfw-pc-checkout-bergwiese" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <div id="bfw-pc-price-bergwiese" class="text-sm text-muted dark:text-slate-400 italic mb-3">Bitte Datum wählen</div>
              <p id="bfw-pc-date-error-bergwiese" class="hidden text-xs text-red-600 mb-2">Bitte gültige Daten wählen.</p>
              <a href="/contact?apartment=bergwiese" id="bfw-pc-cta-bergwiese" class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors">Buchungsanfrage</a>
            </div>

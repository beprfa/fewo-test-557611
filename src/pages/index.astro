  { src: alpenpanorama_1, alt: 'Alpenpanorama 1' },
  { src: alpenpanorama_2, alt: 'Alpenpanorama 2' },
  { src: alpenpanorama_3, alt: 'Alpenpanorama 3' },
  { src: alpenpanorama_4, alt: 'Alpenpanorama 4' },
  { src: alpenpanorama_5, alt: 'Alpenpanorama 5' },
  { src: alpenpanorama_6, alt: 'Alpenpanorama 6' },
  { src: alpenpanorama_7, alt: 'Alpenpanorama 7' },
  { src: alpenpanorama_8, alt: 'Alpenpanorama 8' },
];

const bergwieseImages = [
  { src: bergwiese_1, alt: 'Bergwiese 1' },
  { src: bergwiese_2, alt: 'Bergwiese 2' },
  { src: bergwiese_3, alt: 'Bergwiese 3' },
  { src: bergwiese_4, alt: 'Bergwiese 4' },
  { src: bergwiese_5, alt: 'Bergwiese 5' },
  { src: bergwiese_6, alt: 'Bergwiese 6' },
];

const landhausImages = [
  { src: lh1, alt: 'Musterhaus Sonnenschein Landhaus' },
  { src: lh2, alt: 'Musterhaus Sonnenschein Garten' },
  { src: lh3, alt: 'Musterhaus Sonnenschein Terrasse' },
  { src: lh4, alt: 'Musterhaus Sonnenschein Umgebung' },
  { src: lh5, alt: 'Musterhaus Sonnenschein Aussicht' },
  { src: lh6, alt: 'Musterhaus Sonnenschein Eingang' },
];

const metadata = {
  title: 'Musterhaus Sonnenschein – Ferienwohnungen in Aschau im Chiemgau',
  ignoreTitleTemplate: true,
};
---

<!-- BFW-352: tenant slug + public API base URL for the AvailabilityCalendar widget.
     Markers are replaced by WebsiteContentReplacer at publish time. -->
<script is:inline define:vars={{ tenantSlug: '557611', apiBase: 'http://localhost:9080' }}>
  window.MFWS_TENANT_SLUG = tenantSlug;
  window.MFWS_PUBLIC_API_BASE_URL = apiBase;
</script>

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'secondary',
        text: 'Buchungsanfrage',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { variant: 'primary', text: 'Wohnungen ansehen', href: '#ferienwohnungen' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Musterhaus Sonnenschein – Ferienwohnungen in Aschau im Chiemgau' }}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-white">Willkommen in unserer Ferienwohnung</span>
    </Fragment>

    <Fragment slot="subtitle">
      Erholung pur am Chiemsee
    </Fragment>
  </Hero>

  <!-- Ferienwohnungen Section *************** -->

  <section id="ferienwohnungen" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Ferienwohnungen</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">Ihre Ferienwohnungen in Aschau im Chiemgau</h2>
        <p class="text-lg text-muted dark:text-slate-400">
          Nichtraucher-Haus. Haustiere auf Anfrage. Parkplatz vorhanden.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-lg text-default dark:text-slate-300 mb-8">
        <span class="flex items-center gap-1.5"><Icon name="tabler:car" class="w-4 h-4" /> Parkplatz</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:trees" class="w-4 h-4" /> Garten</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sun" class="w-4 h-4" /> Terrasse</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:flame" class="w-4 h-4" /> Grill</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:mood-kid" class="w-4 h-4" /> Kinder willkommen</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:paw" class="w-4 h-4" /> Haustiere erlaubt</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sparkles" class="w-4 h-4" /> 2025 renoviert</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={alpenpanoramaImages} id="alpenpanorama" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Alpenpanorama</h3>
            <p class="text-sm text-muted dark:text-slate-400 mb-3">Unsere größte Wohnung im Erdgeschoss mit schönem Blick auf die Alpen. Ideal für Familien.</p>
            <p class="text-sm font-semibold text-primary mb-3">Ab 60 € / Nacht (1 Pers.) · 75 € / Nacht (2 Pers.) · inkl. 7 % USt</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-3.5 h-3.5" /> 110 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-3.5 h-3.5" /> Wohnzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Einzelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> WLAN</span>
            </div>
            <AvailabilityCalendar apartment="alpenpanorama" id="alpenpanorama" />
            <div class="mt-4 border-t border-gray-200 dark:border-slate-700 pt-4">
              <div class="flex flex-wrap gap-3 mb-3">
                <div>
                  <label for="bfw-pc-checkin-alpenpanorama" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Anreise</label>
                  <input type="date" id="bfw-pc-checkin-alpenpanorama" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
                <div>
                  <label for="bfw-pc-checkout-alpenpanorama" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Abreise</label>
                  <input type="date" id="bfw-pc-checkout-alpenpanorama" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <div id="bfw-pc-price-alpenpanorama" class="text-sm text-muted dark:text-slate-400 italic mb-3">Bitte Datum wählen</div>
              <p id="bfw-pc-date-error-alpenpanorama" class="hidden text-xs text-red-600 mb-2">Bitte gültige Daten wählen.</p>
              <a href="/contact?apartment=alpenpanorama" id="bfw-pc-cta-alpenpanorama" class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors">Buchungsanfrage</a>
            </div>
<script>
(function() {
  var checkinInput = document.getElementById('bfw-pc-checkin-alpenpanorama');
  var checkoutInput = document.getElementById('bfw-pc-checkout-alpenpanorama');
  var priceDisplay = document.getElementById('bfw-pc-price-alpenpanorama');
  var dateError = document.getElementById('bfw-pc-date-error-alpenpanorama');
  var ctaAnchor = document.getElementById('bfw-pc-cta-alpenpanorama');

  var TENANT_SLUG = '557611';
  var APARTMENT_SLUG = 'alpenpanorama';
  var LOCALE = 'de-DE';
  var PLACEHOLDER = 'Bitte Datum wählen';
  var PRICE_ON_REQUEST = 'Preis auf Anfrage';
  var VAT_LABEL = 'inkl. 7 % USt';
  var NIGHTS_LABEL = 'Nächte';
  var ERROR_INVALID = 'Bitte gültige Daten wählen.';
  var ERROR_UNAVAILABLE = 'Preis kann gerade nicht berechnet werden.';
  var BASE_HREF = '/contact?apartment=alpenpanorama';

  var debounceTimer = null;
  var abortController = null;

  function todayStr() {
    var d = new Date();
    return d.toISOString().split('T')[0];
  }

  function dayAfter(isoDate) {
    var d = new Date(isoDate + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    return d.toISOString().split('T')[0];
  }

  function datesValid() {
    var checkIn = checkinInput ? checkinInput.value : '';
    var checkOut = checkoutInput ? checkoutInput.value : '';
    return !!checkIn && !!checkOut && checkOut > checkIn && checkIn >= todayStr();
  }

  function showDateError(show) {
    if (!dateError) return;
    if (show) dateError.classList.remove('hidden');
    else dateError.classList.add('hidden');
  }

  function clearPrice() {
    if (priceDisplay) priceDisplay.textContent = PLACEHOLDER;
    if (ctaAnchor) ctaAnchor.href = BASE_HREF;
  }

  if (checkinInput) checkinInput.min = todayStr();
  if (checkoutInput) checkoutInput.min = dayAfter(todayStr());

  function onCheckinChange() {
    if (checkinInput && checkinInput.value && checkoutInput) {
      var minOut = dayAfter(checkinInput.value);
      checkoutInput.min = minOut;
      if (checkoutInput.value && checkoutInput.value < minOut) {
        checkoutInput.value = '';
      }
    }
    if (datesValid()) showDateError(false);
    onDateChange();
  }

  function onCheckoutChange() {
    if (datesValid()) showDateError(false);
    onDateChange();
  }

  function fetchPrice() {
    var checkIn = checkinInput ? checkinInput.value : '';
    var checkOut = checkoutInput ? checkoutInput.value : '';

    if (!checkIn || !checkOut) { clearPrice(); return; }
    if (checkOut <= checkIn) { clearPrice(); return; }
    if (checkIn < todayStr()) { clearPrice(); return; }

    if (abortController) abortController.abort();
    abortController = new AbortController();

    fetch('/api/public/tenants/' + TENANT_SLUG + '/apartments/' + APARTMENT_SLUG + '/price-calculation', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ checkIn: checkIn, checkOut: checkOut }),
      signal: abortController.signal,
    })
    .then(function(res) {
      if (res.status === 422) {
        if (priceDisplay) priceDisplay.textContent = ERROR_INVALID;
        showDateError(true);
        if (ctaAnchor) ctaAnchor.href = BASE_HREF;
        return null;
      }
      if (!res.ok) {
        if (priceDisplay) priceDisplay.textContent = ERROR_UNAVAILABLE;
        if (ctaAnchor) ctaAnchor.href = BASE_HREF;
        return null;
      }
      return res.json();
    })
    .then(function(data) {
      if (!data) return;
      if (data.totalPrice === null || data.totalPrice === undefined) {
        if (priceDisplay) priceDisplay.textContent = PRICE_ON_REQUEST;
        if (ctaAnchor) ctaAnchor.href = BASE_HREF;
      } else {
        var fmt = function(n) { return n.toLocaleString(LOCALE, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); };
        var nights = data.nights;
        var ppn = data.pricePerNight != null ? fmt(data.pricePerNight) : null;
        var total = data.totalPrice != null ? fmt(data.totalPrice) : null;
        if (priceDisplay) priceDisplay.textContent = nights + ' ' + NIGHTS_LABEL + ' × ' + ppn + ' € = ' + total + ' € · ' + VAT_LABEL;
        var checkIn = checkinInput ? checkinInput.value : '';
        var checkOut = checkoutInput ? checkoutInput.value : '';
        if (ctaAnchor && checkIn && checkOut) {
          ctaAnchor.href = BASE_HREF + '&checkIn=' + encodeURIComponent(checkIn) + '&checkOut=' + encodeURIComponent(checkOut);
        }
      }
    })
    .catch(function(err) {
      if (err && err.name === 'AbortError') return;
      if (priceDisplay) priceDisplay.textContent = ERROR_UNAVAILABLE;
      if (ctaAnchor) ctaAnchor.href = BASE_HREF;
    });
  }

  function onDateChange() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(fetchPrice, 300);
  }

  if (checkinInput) checkinInput.addEventListener('change', onCheckinChange);
  if (checkoutInput) checkoutInput.addEventListener('change', onCheckoutChange);
})();
</script>
          </div>
